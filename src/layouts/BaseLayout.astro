---
import Navbar from '../components/Navbar';
import Footer from '../components/Footer';
import LeadCaptureCTA from '../components/LeadCaptureCTA';
import '../index.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonical?: string;
  keywords?: string;
  schema?: any[];
  noindex?: boolean;
}

const {
  title = "Solarpedia | Impartial UK Solar Advice",
  description = "Independent UK solar insights, cost estimates and savings forecasts powered by real energy and regional data.",
  image = "https://images.unsplash.com/photo-1508514177221-188b1cf16e9d?auto=format&fit=crop&w=1200&q=80",
  canonical = "https://solarpedia.co.uk",
  keywords = "Is solar worth it UK, Solar cost calculator UK, Commercial solar calculator, Solar savings estimator, Solar ROI calculator, Business solar savings",
  schema = [],
  noindex = false
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=AW-18339897698"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'AW-18339897698');
    </script>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/svg+xml" href="/vite.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    {noindex ? <meta name="robots" content="noindex, nofollow" /> : <meta name="robots" content="index, follow" />}
    <link rel="canonical" href={canonical} />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@400;600;700&display=swap" rel="stylesheet">
    
    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title}>
    <meta name="description" content={description}>
    <meta name="keywords" content={keywords}>
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website">
    <meta property="og:url" content={canonical}>
    <meta property="og:site_name" content="Solarpedia UK">
    <meta property="og:title" content={title}>
    <meta property="og:description" content={description}>
    <meta property="og:image" content={image}>
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content={title}>
    <meta name="twitter:description" content={description}>
    <meta name="twitter:image" content={image}>
    
    <!-- Structured Data -->
    {schema.map(s => (
      <script type="application/ld+json" is:inline set:html={JSON.stringify(s)} />
    ))}

    <script>
      import { trackPageView } from '../lib/tracking';
      
      // Track on initial load
      trackPageView();

      // Track on view transition if enabled (Solarpedia doesn't seem to use ViewTransitions yet, but good for future)
      document.addEventListener('astro:page-load', () => {
        trackPageView();
      });
    </script>
  </head>
  <body class="bg-brand-white text-brand-navy antialiased">
    <form name="get-3-free-solar-quotes" data-netlify="true" data-netlify-honeypot="bot-field" hidden>
      <input type="hidden" name="form-name" value="get-3-free-solar-quotes" />
      <input name="bot-field" />
      <input name="name" />
      <input name="email" />
      <input name="phone" />
      <input name="postcode" />
      <input name="propertyType" />
      <input name="page" />
    </form>
    <div class="flex flex-col min-h-screen">
      <Navbar client:load />
      <main class="flex-grow">
        <slot />
        <LeadCaptureCTA client:visible />
      </main>
      <Footer />
    </div>
  </body>
</html>

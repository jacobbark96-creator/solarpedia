---
import BaseLayout from '../layouts/BaseLayout.astro';
import Results from '../components/pages/Results';
import { createBreadcrumbSchema, buildAbsoluteUrl } from '../lib/seo';

const title = 'Your Solar Forecast | Solarpedia';
const description = 'View your personalised solar savings estimate, ROI projection, and system recommendations.';
const path = '/results';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Solar Forecast Results",
    "description": "A personalised solar estimate generated from the Solarpedia savings calculator.",
    "url": buildAbsoluteUrl(path),
  },
  createBreadcrumbSchema([
    { name: 'Home', path: '/' },
    { name: 'Solar Savings Wizard', path: '/wizard' },
    { name: 'Solar Forecast', path: path },
  ]),
];
---

<BaseLayout 
  title={title} 
  description={description} 
  schema={schema}
  canonical={buildAbsoluteUrl(path)}
>
  <Results client:only="react" />
</BaseLayout>